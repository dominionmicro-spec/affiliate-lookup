# REQUIRED: The ID from your Google Sheet URL
# Found in: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=replace_with_your_sheet_id_here

# REQUIRED: The service account email from your Google Cloud JSON key
# Found in the downloaded JSON file as "client_email"
GOOGLE_SERVICE_ACCOUNT_EMAIL=replace_with_your_service_account_email_here

# REQUIRED: The private key from your Google Cloud JSON key
# Found in the downloaded JSON file as "private_key"
# Copy the full value including "-----BEGIN PRIVATE KEY-----" and "-----END PRIVATE KEY-----"
# Keep the double quotes. The \n sequences are intentional.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE_WITH_MANY_LINES\n-----END PRIVATE KEY-----\n"
